PORT=8080
MONGODB_URI=replace_with_mongodb_uri
GEMINI_API_KEYS=replace_with_key_1,replace_with_key_2,replace_with_key_3,replace_with_key_4,replace_with_key_5
# ID ổn định, không phải secret; thứ tự phải khớp GEMINI_API_KEYS.
GEMINI_PROJECT_IDS=project_01,project_02,project_03,project_04,project_05
GEMINI_SCHEDULER_MODE=project_pool
# Alias cũ; chỉ dùng khi GEMINI_ELIGIBLE_PROJECT_LIMIT chưa được cấu hình.
GEMINI_ACTIVE_PROJECT_LIMIT=5
# Đặt 50 ở production sau khi GEMINI_API_KEYS/GEMINI_PROJECT_IDS có đủ 50 phần tử.
GEMINI_ELIGIBLE_PROJECT_LIMIT=5
GEMINI_PROJECT_GROUP_SIZE=5
GEMINI_PROJECT_GROUP_ROTATION_ENABLED=true
GEMINI_INITIAL_CONCURRENCY=5
GEMINI_MAX_CONCURRENCY=10
GEMINI_PROJECT_RPM=15
GEMINI_PROJECT_TPM=250000
GEMINI_PROJECT_RPD=500
GEMINI_PROJECT_HEADROOM=0.9
GEMINI_PROJECT_MAX_IN_FLIGHT=2
GEMINI_MODEL=gemini-3.5-flash-lite
FRONTEND_URL=http://localhost:5173
# Mã quản trị chỉ nhập trên giao diện khi tạm dừng/tiếp tục hàng đợi để redeploy.
MAINTENANCE_CONTROL_TOKEN=replace_with_a_long_random_secret
MAX_UPLOAD_STORAGE_MB=400
MAX_FILE_SIZE_MB=350
MAX_JOB_ATTEMPTS=3
TRANSLATION_WORKER_CONCURRENCY=3
PARALLEL_SOURCE_BUDGET_MB=15
GEMINI_TIMEOUT_MS=180000
TRANSLATION_PIPELINE_MODE=quality
PDF_PAGES_PER_CHUNK=2
GEMINI_THINKING_LEVEL=HIGH
QUALITY_MAX_REPAIR_CYCLES=2
R2_ACCOUNT_ID=replace_with_cloudflare_account_id
R2_ACCESS_KEY_ID=replace_with_r2_access_key_id
R2_SECRET_ACCESS_KEY=replace_with_r2_secret_access_key
R2_BUCKET_NAME=tranmed-pdf-staging
R2_ENDPOINT=https://replace_with_cloudflare_account_id.r2.cloudflarestorage.com
R2_REGION=auto
R2_PRESIGNED_URL_TTL_SECONDS=1800
R2_UPLOAD_CONCURRENCY=4
R2_SOURCE_RETENTION_DAYS=7
